{
  "name": "box-shadow",
  "version": "0.2.0",
  "description": "Visual tool for css property box-shadow",
  "main": "index.js",
  "scripts": {
    "dev": "webpack serve --config webpack.dev.js",
    "transpile": "babel ./src --out-dir ./js --extensions .ts,.js,.tsx,.jsx",
    "lint:one": "eslint -c eslint.config.js",
    "lint:biome": "npx @biomejs/biome lint ./src > _lint.txt 2>&1",
    "tsc:check": "tsc --noEmit",
    "build:dll": "webpack --color --progress --config webpack.dll.js",
    "build:dll-tsx": "webpack --color --progress --config webpack.dll-tsx.js",
    "build:prod": "npm run build:dll && npm run build:dll-tsx",
    "css:min": "node css-min.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "css-box-shadow",
    "css-tool"
  ],
  "author": "Yevhenii Molodyi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZhnZhn/css-tool.git"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "preact": "^10.29.7"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/eslint-plugin": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@biomejs/biome": "^2.5.4",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/tinycolor2": "^1.4.6",
    "babel-loader": "^10.1.1",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "sass": "^1.101.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-loader": "^9.6.2",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "overrides": {
    "glob": "~13.0.6",
    "uuid": "~14.0.0",
    "js-yaml": "~4.3.0",
    "http-proxy-middleware": "~4.1.1"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/js/__tests__/global.setup.js"
    ],
    "roots": [
      "<rootDir>/js/colors",
      "<rootDir>/js/components/box-shadow",
      "<rootDir>/js/components/zhn",
      "<rootDir>/js/utils"
    ],
    "transformIgnorePatterns": [
      "<rootDir>/js/colors",
      "<rootDir>/js/components/box-shadow",
      "<rootDir>/js/components/zhn",
      "<rootDir>/js/utils"
    ],
    "testMatch": [
      "**/__tests__/**/*.+(js)"
    ]
  }
}
